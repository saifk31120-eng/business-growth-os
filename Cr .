const makeImg = (p) =>
  `https://image.pollinations.ai/prompt/${encodeURIComponent(
    p + ", professional, ultra high quality, 8k, award winning, corporate"
  )}?width=700&height=450&nologo=true&enhance=true&seed=${Math.floor(Math.random() * 99999)}`;

const makeFrames = (desc) =>
  Array.from({ length: 6 }, (_, i) =>
    `https://image.pollinations.ai/prompt/${encodeURIComponent(
      desc + `, cinematic frame ${i + 1} of 6, professional, 8k`
    )}?width=640&height=360&nologo=true&enhance=true&seed=${Date.now() + i * 4444}`
  );

const parseParts = (text) => {
  const parts = [], lines = text.split("\n");
  let buf = [];
  for (const l of lines) {
    if (l.includes("GENERATE_IMAGE:")) {
      if (buf.join("").trim()) { parts.push({ type: "text", content: buf.join("\n").trim() }); buf = []; }
      const p = l.replace("GENERATE_IMAGE:", "").trim();
      if (p) parts.push({ type: "image", prompt: p });
    } else if (l.includes("GENERATE_VIDEO:")) {
      if (buf.join("").trim()) { parts.push({ type: "text", content: buf.join("\n").trim() }); buf = []; }
      const p = l.replace("GENERATE_VIDEO:", "").trim();
      if (p) parts.push({ type: "video", desc: p });
    } else buf.push(l);
  }
  if (buf.join("").trim()) parts.push({ type: "text", content: buf.join("\n").trim() });
  return parts;
};

