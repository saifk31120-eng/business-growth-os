function VideoCard({ desc }) {
  const [frames] = useState(() => makeFrames(desc));
  const [cur, setCur] = useState(0);
  const [playing, setPlaying] = useState(false);
  const [loaded, setLoaded] = useState(0);
  const ivl = useRef(null);
  useEffect(() => {
    if (playing) ivl.current = setInterval(() => setCur(p => (p + 1) % frames.length), 700);
    else clearInterval(ivl.current);
    return () => clearInterval(ivl.current);
  }, [playing, frames.length]);
  const ready = loaded >= frames.length;
  return (
    <div style={{ borderRadius: "14px", overflow: "hidden", border: "1px solid #d4af3720", background: "#0d0d1a", marginTop: "8px" }}>
      {frames.map((f, i) => <img key={i} src={f} onLoad={() => setLoaded(p => p + 1)} alt="" style={{ display: "none" }} />)}
      <div style={{ padding: "8px 14px", background: "#d4af3708", borderBottom: "1px solid #d4af3712", display: "flex", alignItems: "center", gap: "8px" }}>
        <div style={{ width: "7px", height: "7px", borderRadius: "50%", background: "#d4af37" }} />
        <span style={{ color: "#d4af37", fontSize: "10px", fontWeight: "700", letterSpacing: "1px" }}>AI VIDEO · {frames.length} FRAMES</span>
        <span style={{ marginLeft: "auto", padding: "2px 8px", background: ready ? "#d4af3715" : "#ffffff10", border: `1px solid ${ready ? "#d4af3730" : "#ffffff15"}`, borderRadius: "8px", color: ready ? "#d4af37" : "#ffffff50", fontSize: "9px", fontWeight: "700" }}>{ready ? "▶ READY" : `${loaded}/${frames.length}`}</span>
      </div>
      <div style={{ position: "relative", minHeight: "140px", background: "#08080f" }}>
        {!ready ? (
          <div style={{ position: "absolute", inset: 0, display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", gap: "12px" }}>
            <div style={{ width: "40px", height: "40px", border: "2px solid #d4af3720", borderTop: "2px solid #d4af37", borderRadius: "50%", animation: "spin .6s linear infinite" }} />
            <div style={{ width: "150px", height: "2px", background: "#ffffff08", borderRadius: "1px" }}>
              <div style={{ height: "100%", background: "linear-gradient(90deg,#d4af37,#b89620)", width: `${(loaded / frames.length) * 100}%`, transition: "width .3s", borderRadius: "1px" }} />
            </div>
          </div>
        ) : (
          <div>
            <img src={frames[cur]} alt="" style={{ width: "100%", display: "block" }} />
            <div style={{ position: "absolute", bottom: 0, left: 0, right: 0, padding: "10px 14px", background: "linear-gradient(transparent,rgba(0,0,0,0.9))" }}>
              <div style={{ display: "flex", alignItems: "center", gap: "8px", marginBottom: "6px" }}>
                <button onClick={() => setPlaying(p => !p)} style={{ width: "26px", height: "26px", background: "#d4af37", border: "none", borderRadius: "50%", color: "#000", cursor: "pointer", fontSize: "10px", display: "flex", alignItems: "center", justifyContent: "center", fontWeight: "900" }}>{playing ? "⏸" : "▶"}</button>
                <div style={{ flex: 1, height: "2px", background: "rgba(255,255,255,0.15)", borderRadius: "1px", cursor: "pointer" }} onClick={e => { const r = e.currentTarget.getBoundingClientRect(); setCur(Math.min(Math.floor(((e.clientX - r.left) / r.width) * frames.length), frames.length - 1)); }}>
                  <div style={{ height: "100%", background: "#d4af37", width: `${((cur + 1) / frames.length) * 100}%`, borderRadius: "1px" }} />
                </div>
                <span style={{ color: "rgba(255,255,255,0.5)", fontSize: "9px" }}>{cur + 1}/{frames.length}</span>
              </div>
              <div style={{ display: "flex", gap: "3px" }}>
                {frames.map((f, i) => <img key={i} src={f} alt="" onClick={() => setCur(i)} style={{ height: "22px", width: "40px", objectFit: "cover", borderRadius: "3px", cursor: "pointer", border: `1px solid ${i === cur ? "#d4af37" : "transparent"}`, opacity: i === cur ? 1 : 0.4 }} />)}
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

